{
  "name": "white",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "author": "Aino",
  "scripts": {
    "conf": "bun @white/scripts/conf.ts",
    "dev": "vite --port $(bun conf PORT)",
    "api": "nodemon --watch @white/lib/devServer.js --watch api/ @white/lib/devServer.js",
    "dev:api": "bun --bun run dev & bun --bun run api & wait",
    "build": "vite build",
    "build:isr": "WHITE_ASSETS_ONLY=1 vite build && node @white/build/compile-templates.js",
    "vercel-build": "node @white/build/vercel-build.js",
    "start": "node @white/lib/previewServer.js",
    "lint": "eslint .",
    "deploy:isr": "node @white/deploy/deploy.js"
  },
  "devDependencies": {
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "express": "^5.1.0",
    "fs-extra": "^11.2.0",
    "glob": "^11.0.0",
    "globals": "^15.13.0",
    "lightningcss": "^1.30.1",
    "nodemon": "^3.1.10",
    "prettier": "^3.8.1",
    "sharp": "0.33.5",
    "terser": "^5.44.1",
    "vercel": "^39.1.2",
    "vite": "^8.0.7",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-eslint2": "^5.1.0",
    "vite-plugin-full-reload": "^1.2.0",
    "vite-plugin-minify": "^2.0.1"
  },
  "dependencies": {
    "@aws-sdk/client-cloudfront": "^3.1015.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.1017.0",
    "@aws-sdk/client-s3": "^3.1015.0",
    "lz-string": "^1.5.0"
  }
}
